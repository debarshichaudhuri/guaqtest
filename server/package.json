{
  "name": "guaqai-server",
  "version": "1.0.0",
  "description": "GuaqAI Hospitality Management Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "ts-node src/seed.ts",
    "test": "ts-node tests/e2e.ts",
    "test:url": "TEST_URL=$TEST_URL ts-node tests/e2e.ts"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@prisma/client": "^5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.22.0",
    "telegraf": "^4.16.3",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2"
  }
}
